{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "PowerCatalogOutput",
  "description": "Versioned collection of calibrated power coefficients per media class, suitable for merging into hardware-catalog.v1.yaml.",
  "type": "object",
  "required": ["media_classes"],
  "properties": {
    "media_classes": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "id",
          "media_type",
          "generation",
          "pidle_w_per_tb",
          "pactive_w_per_tb",
          "_calibration"
        ],
        "properties": {
          "id": {
            "type": "string",
            "description": "Identifier matching hardware-catalog.v1.yaml media_class id"
          },
          "media_type": {
            "type": "string"
          },
          "generation": {
            "type": "string"
          },
          "pidle_w_per_tb": {
            "type": "number",
            "minimum": 0.0
          },
          "pactive_w_per_tb": {
            "type": "number",
            "minimum": 0.0
          },
          "power_curve": {
            "type": "array",
            "minItems": 2,
            "items": {
              "type": "object",
              "required": ["utilization", "watts_per_tb"],
              "properties": {
                "utilization": {
                  "type": "number",
                  "minimum": 0.0,
                  "maximum": 1.0
                },
                "watts_per_tb": {
                  "type": "number",
                  "minimum": 0.0
                }
              },
              "additionalProperties": false
            }
          },
          "_calibration": {
            "type": "object",
            "required": [
              "run_id",
              "method",
              "rmse_w_per_tb",
              "max_abs_err_w_per_tb",
              "sample_count",
              "time_range_start",
              "time_range_end",
              "source_id",
              "module_version",
              "k",
              "e",
              "r",
              "ew"
            ],
            "properties": {
              "run_id": { "type": "string" },
              "method": { "type": "string" },
              "rmse_w_per_tb": {
                "type": "number",
                "minimum": 0.0
              },
              "max_abs_err_w_per_tb": {
                "type": "number",
                "minimum": 0.0
              },
              "sample_count": {
                "type": "integer",
                "minimum": 1
              },
              "time_range_start": {
                "type": "string",
                "format": "date-time"
              },
              "time_range_end": {
                "type": "string",
                "format": "date-time"
              },
              "source_id": {
                "type": "string"
              },
              "module_version": {
                "type": "string"
              },
              "k": {
                "type": "number",
                "minimum": 0.0,
                "maximum": 1.0
              },
              "e": {
                "type": "number",
                "minimum": 0.0,
                "maximum": 1.0
              },
              "r": {
                "type": "number",
                "minimum": 0.0,
                "maximum": 1.0
              },
              "ew": {
                "type": "number",
                "minimum": 0.0,
                "maximum": 1.0
              }
            },
            "additionalProperties": false
          }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
