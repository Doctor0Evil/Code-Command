!-- FILE .connectors/chatgpt/sandbox.aln --
kind connector-sandbox
version 1.0.0
platform "chatgpt"

allowed_apis:
  - "fetch:https://api.github.com"
  - "ccInitVfs"
  - "ccValidateCode"
  - "ccExecuteTask"
  - "console.log"

banned_globals:
  - "window"
  - "document"
  - "localStorage"
  - "sessionStorage"
  - "fetch:*"           # any non-whitelisted fetch target
  - "XMLHttpRequest"
  - "WebSocket"
  - "EventSource"
  - "Worker"
  - "SharedWorker"
  - "BroadcastChannel"
  - "eval"
  - "Function"
  - "import()"
  - "require"
  - "process"
  - "global"
  - "globalThis"
  - "navigator"
  - "IndexedDB"

max_runtime_ms: 2000
