!-- FILE .specs/wiring-spec.aln --
kind wiring-spec
version 1.1.0

# Core engine nodes as defined in DR45 / DR36
nodes:
  - id: "Lib"
    type: "core"
  - id: "Validator"
    type: "core"
  - id: "Vfs"
    type: "core"
  - id: "Navigator"
    type: "core"
  - id: "TaskQueue"
    type: "core"
  - id: "TokenWalker"
    type: "aux"
  - id: "Logging"
    type: "cross-cutting"

# Canonical wiring edges between engine modules.
# Each entry declares the allowed/expected cross-module calls.
edges:
  # Lib orchestrates all operations via WASM exports / CC-API
  - from: "Lib"
    to:   "Vfs"
    via:  ["ccinitvfs", "ccreadfile", "ccwritefile", "cclistdir"]
  - from: "Lib"
    to:   "Validator"
    via:  ["ccvalidatecode"]
  - from: "Lib"
    to:   "TaskQueue"
    via:  ["ccexecutetask"]

  # TaskQueue executes tasks with validation
  - from: "TaskQueue"
    to:   "Vfs"
    via:  ["read", "write"]
  - from: "TaskQueue"
    to:   "Validator"
    via:  ["run_validation"]

  # Navigator traverses VFS tree (CC-NAV)
  - from: "Navigator"
    to:   "Vfs"
    via:  ["walkdir", "list"]

  # Validator uses TokenWalker for structural analysis (Tier-2)
  - from: "Validator"
    to:   "TokenWalker"
    via:  ["scan", "token_walker"]

  # Cross-cutting logging / metrics wrappers
  - from: "TaskQueue"
    to:   "Logging"
    via:  ["log_task"]
  - from: "Validator"
    to:   "Logging"
    via:  ["log_validation"]

# High-level wiring invariants that the wiring validator must enforce.
invariants:
  # Lib may not bypass TaskQueue or Validator for navigation or structural scans.
  - id: "INV-0001"
    description: "Lib must not call Navigator or TokenWalker directly."
    forbidden_edge:
      from: "Lib"
      to:   "Navigator"
  - id: "INV-0002"
    description: "Lib must not call TokenWalker directly."
    forbidden_edge:
      from: "Lib"
      to:   "TokenWalker"

  # TaskQueue must operate via Vfs and Validator only (no Navigator shortcuts).
  - id: "INV-0003"
    description: "TaskQueue must not call Navigator directly."
    forbidden_edge:
      from: "TaskQueue"
      to:   "Navigator"

  # Lib may only reach Vfs via TaskQueue in validate/write flows.
  # Direct Lib -> Vfs edges are restricted to CC-API exports.
  - id: "INV-0004"
    description: "Lib may only reach Vfs via TaskQueue for task execution flows."
    path_constraint:
      source: "Lib"
      target: "Vfs"
      allowed_via: ["TaskQueue"]

  # All validate-only flows must go through Validator.
  - id: "INV-0005"
    description: "All validate-only flows must go through Validator."
    required_edge:
      from: "TaskQueue"
      to:   "Validator"
      via:  ["run_validation"]
